# ─── Modal GPU Server ───────────────────────────────────────────
# Option A: Auto-deploy (recommended) — just set your Modal token.
# Get it at https://modal.com/settings/tokens
# The Docker container will deploy server.py on first boot.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Option B: Already deployed — set the URL directly.
# VOICE_SERVER_URL=https://your-org--aris-voice-server.modal.run

# ─── OpenClaw Bridge (recommended) ──────────────────────────────
# Routes voice through your OpenClaw instance — memory, tools, coaching.
# When set, OpenClaw handles all LLM logic. No OpenRouter key needed.
OPENCLAW_GATEWAY_URL=ws://192.168.178.134:18789
OPENCLAW_GATEWAY_TOKEN=your-token-here

# ─── Direct LLM mode (fallback — only if NOT using OpenClaw) ───
# Leave OPENCLAW_GATEWAY_URL empty and set these instead:
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# LLM_MODEL=xiaomi/mimo-v2-pro

# ─── Optional ───────────────────────────────────────────────────
BOT_PORT=7860
FISH_VOICE_ID=
WHISPER_MODEL=large-v3
