# ─── Required ───────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── Fish Speech Self-Hosted ───────────────────────────────────
# URL of your self-hosted Fish Speech S2 Pro server
# Local:   http://localhost:8080
# Modal:   https://your-app.modal.run (from `modal deploy fish_speech_server.py`)
FISH_SPEECH_URL=http://localhost:8080

# Voice reference ID (optional — for voice cloning)
# Leave empty for default voice
FISH_VOICE_ID=

# ─── Optional ───────────────────────────────────────────────────
# LLM model (default: xiaomi/mimo-v2-pro)
# Any OpenRouter model works: anthropic/claude-sonnet-4-20250514, openai/gpt-4o, etc.
LLM_MODEL=xiaomi/mimo-v2-pro

# Whisper model: large-v3 (default), medium, small, base
WHISPER_MODEL=large-v3

# ─── Daily.co (for production WebRTC) ───────────────────────────
# Only needed if using Daily transport instead of local SmallWebRTC
DAILY_API_KEY=
DAILY_API_URL=https://api.daily.co
